#include <iostream>
using namespace std;

string encrypt(string text, string key)
{
    string cipher = "";

    for (int i = 0, j = 0; i < text.length(); i++)
    {
        char c = text[i];

        if (isalpha(c))
        {
            char base = isupper(c) ? 'A' : 'a';
            cipher += char((c - base + (tolower(key[j % key.length()]) - 'a')) % 26 + base);
            j++;
        }
        else
        {
            cipher += c;
        }
    }

    return cipher;
}

int main()
{
    string text = "HELLO";
    string key = "KEY";

    cout << "Plain Text : " << text << endl;
    cout << "Key        : " << key << endl;
    cout << "Cipher     : " << encrypt(text, key) << endl;

    return 0;
}

